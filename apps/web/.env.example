# PostHog analytics (client-side key — safe to expose in the browser)
# Project token from PostHog project settings.
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token_here
# PostHog ingestion host. Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU).
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
