{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "vite/client",
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@better-ttb/generator": [
        "../../packages/generator/src/index.ts"
      ],
      "@/*": [
        "./src/*"
      ],
      "@better-ttb/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
