# Alchemy state encryption password (used by `alchemy deploy`).
ALCHEMY_PASSWORD=

# Auth token for the DOStateStore worker that holds remote deploy state.
# Use any strong random string; it MUST be identical locally and in CI.
ALCHEMY_STATE_TOKEN=

# Cloudflare API token (deploy). Locally you can rely on `wrangler login`
# instead, but CI needs this set explicitly.
CLOUDFLARE_API_TOKEN=

# Deploy stage -> worker name suffix (better-ttb-web-<STAGE>). Defaults to "prod".
# STAGE=prod

# Admin token bound into the Worker (falls back to "dev-admin-token" if unset).
ADMIN_TOKEN=

# --- PostHog source-map upload (deploy only) ---
# Used by `npm run sourcemaps:upload` to de-minify production stack traces.
# Create a personal API key with "Error tracking" write scope in PostHog.
# In Cloudflare CI set these as build environment variables instead of a file.
POSTHOG_CLI_API_KEY=phx_your_personal_api_key_here
POSTHOG_CLI_PROJECT_ID=your_project_id
# App host (NOT the ingest host). Defaults to https://us.posthog.com if unset.
POSTHOG_CLI_HOST=https://us.posthog.com
